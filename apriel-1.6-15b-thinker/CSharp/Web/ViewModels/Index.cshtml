@page "/Index"
@model YourApp.Web.ViewModels.ActivityListViewModel
@{
    ViewData["Title"] = "Activities";
}
<h2>Activities</h2>
<a asp-page="/Create" asp-controller="Activities" class="btn btn-success mb-3">New Activity</a>

<table class="table">
    <thead>
        <tr><th>Name</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@(item.ProgressStatus ?? "N/A")</td>
                <td>
                    <a asp-page="/Details" asp-controller="Activities">Details</a> |
                    <a asp-page="/Edit" asp-controller="Activities">Edit</a> |
                    <a asp-page="/Delete" asp-controller="Activities">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination">
        @if (Model.PageNumber > 0)
        {
            <li class="page-item"><a class="page-link" href="?page=@(Model.PageNumber - 1)">Previous</a></li>
        }
        @for (int i = 0; i < (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
        {
            <li class="page-item @(i == Model.PageNumber ? "active" : "")"><a class="page-link" href="?page=@i">@i + 1</a></li>
        }
        <li class="page-item"><a class="page-link" href="?page=@(Model.PageNumber + 1)">Next</a></li>
    </ul>
</nav>
