@page "/Delete"
@model YourApp.Web.ViewModels.ActivityUpdateViewModel
@{
    ViewData["Title"] = "Confirm Delete";
}
<div class="alert alert-warning">Are you sure you want to delete this activity?</div>
<form asp-action="OnPost" method="post">
    <button type="submit" class="btn btn-danger mt-2">Delete</button>
    <a asp-page="/Index" asp-controller="Activities" class="btn btn-secondary">Cancel</a>
</form>
