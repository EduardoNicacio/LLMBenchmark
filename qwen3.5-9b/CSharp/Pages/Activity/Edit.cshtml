<!-- Pages/Activity/Edit.cshtml -->
@page
@model ActivityApp.Pages.Activity.EditModel
@{
    ViewData["Title"] = "Edit Activity";
}
<h1>Edit Activity</h1>
<form method="post">
    <div>
        <label>Name</label>
        <input asp-for="ViewModel.Name" />
        <span asp-validation-for="ViewModel.Name"></span>
    </div>
    <div>
        <label>Description</label>
        <textarea asp-for="ViewModel.Description"></textarea>
        <span asp-validation-for="ViewModel.Description"></span>
    </div>
    <div>
        <label>Tags</label>
        <input asp-for="ViewModel.Tags" />
    </div>
    <div>
        <label>ActiveFlag</label>
        <input asp-for="ViewModel.ActiveFlag" />
    </div>
    <button type="submit">Update</button>
</form>
